// ── HELPERS ───────────────────────────────────────────────────────────────────
function fmt(n){if(n==null)return'—';if(n>=1e9)return'£'+(n/1e9).toFixed(1)+'bn';if(n>=1e6)return'£'+(n/1e6).toFixed(0)+'M';if(n>=1e3)return'£'+(n/1e3).toFixed(0)+'k';return'£'+n;}
function fmtFull(n){if(n==null)return'—';return'£'+n.toLocaleString();}
function fmtYoc(v){return v?(v*100).toFixed(2)+'%':'—';}
function or(v){return(v!=null&&v!=='')?(typeof v==='number'?v:v):'—';}
function val(v){return(v!=null&&v!=='') ? v : null;}

function pillCls(s){
  const m={Acquired:'acquired',Exclusivity:'exclusivity','Advanced Discussions':'advanced','Early Discussions':'early','On Hold':'hold','Potential Opportunities':'potential',Declined:'declined',Lost:'lost'};
  return'pill-'+(m[s]||'hold');
}
function pillLbl(s){
  const m={'Advanced Discussions':'Advanced','Early Discussions':'Early Stage','Potential Opportunities':'Potential'};
  return m[s]||s;
}
function dotColor(s){
  const m={Acquired:'#2d5a3d',Exclusivity:'#b8830a','Advanced Discussions':'#2a4a6b','Early Discussions':'#7a7460','On Hold':'#5a5650','Potential Opportunities':'#5a3d6b'};
  return m[s]||'#aaa';
}
function cityMatch(d,f){
  if(f==='London')return d.city&&d.city.toLowerCase().includes('london');
  if(f==='Bristol')return d.city==='Bristol';
  if(f==='Other')return d.city&&!d.city.toLowerCase().includes('london')&&d.city!=='Bristol';
  return true;
}

// ── KPIs ──────────────────────────────────────────────────────────────────────
function renderKPIs(){
  const activeStatuses=['Acquired','Exclusivity','Advanced Discussions','Early Discussions'];
  const active=liveDeals.filter(d=>activeStatuses.includes(d.status));
  const beds=liveDeals.reduce((s,d)=>s+(d.beds||0),0);
  const gdv=liveDeals.filter(d=>d.gdv).reduce((s,d)=>s+d.gdv,0);
  const eq=active.filter(d=>d.equity).reduce((s,d)=>s+d.equity,0);
  const decCount=declinedDeals.filter(d=>d.status==='Declined').length;
  document.getElementById('headerDate').textContent=new Date().toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'});
  document.getElementById('kpiGrid').innerHTML=`
    <div class="kpi"><div class="kpi-label">Pipeline Deals</div><div class="kpi-value gold">${liveDeals.length}</div><div class="kpi-sub">${active.length} active</div></div>
    <div class="kpi"><div class="kpi-label">Total Beds</div><div class="kpi-value">${beds.toLocaleString()}</div><div class="kpi-sub">live pipeline</div></div>
    <div class="kpi"><div class="kpi-label">Pipeline GDV</div><div class="kpi-value gold">${fmt(gdv)}</div><div class="kpi-sub">where known</div></div>
    <div class="kpi"><div class="kpi-label">Equity Required</div><div class="kpi-value">£${(eq/1e6).toFixed(0)}M</div><div class="kpi-sub">active deals</div></div>
    <div class="kpi"><div class="kpi-label">Declined</div><div class="kpi-value red-val">${decCount}</div><span class="kpi-link" onclick="switchTabByName('declined')">view all</span></div>`;
}

// ── CARDS ─────────────────────────────────────────────────────────────────────
function renderCards(data){
  const order=['Acquired','Exclusivity','Advanced Discussions','Early Discussions','Potential Opportunities','On Hold'];
  const grouped={};order.forEach(s=>grouped[s]=[]);
  data.forEach(d=>{if(grouped[d.status])grouped[d.status].push(d);});
  let html='';
  order.forEach(s=>{
    const g=grouped[s];if(!g.length)return;
    html+=`<div class="status-section"><div class="status-heading"><span class="status-dot" style="background:${dotColor(s)}"></span><span class="status-heading-text">${s}</span><span class="status-count">${g.length}</span></div><div class="cards-grid">`;
    g.forEach((d,i)=>{
      const idx=liveDeals.indexOf(d);
      const st=d.studios!=null?`${d.studios}s / ${d.ensuite!=null?d.ensuite:'—'}e`:(d.ensuite!=null?`${d.ensuite}e`:'');
      html+=`<div class="deal-card" onclick="openModal(${idx})">
        <div class="deal-card-top"><div class="deal-address">${d.address||'—'}</div><span class="deal-status-pill ${pillCls(d.status)}">${pillLbl(d.status)}</span></div>
        <div class="deal-location">${d.neighbourhood?d.neighbourhood+', ':''}<strong>${d.city.replace('London - ','')}</strong></div>
        <div class="deal-metrics">
          <div class="metric-box"><div class="metric-label">Beds</div><div class="metric-value">${d.beds||'—'}</div>${st?`<div class="metric-sub">${st}</div>`:''}</div>
          <div class="metric-box"><div class="metric-label">Land Price</div><div class="metric-value">${d.landPrice?fmt(d.landPrice):'—'}</div>${d.totalCost?`<div class="metric-sub">Cost ${fmt(d.totalCost)}</div>`:''}</div>
          <div class="metric-box"><div class="metric-label">Equity</div><div class="metric-value">${d.equity?fmt(d.equity):'—'}</div>${d.gdv?`<div class="metric-sub">GDV ${fmt(d.gdv)}</div>`:''}</div>
        </div>
        <div class="deal-tags">
          ${d.marketing?`<span class="tag">${d.marketing}</span>`:''}
          ${d.ptal?`<span class="tag gold-tag">${d.ptal}</span>`:''}
          ${d.developer?`<span class="tag">${d.developer}</span>`:''}
          ${d.intake?`<span class="deal-intake">AY ${d.intake}</span>`:''}
        </div>
        ${d.notes?`<div class="deal-notes">${d.notes}</div>`:''}
        <div class="card-hint">Click for full details →</div>
      </div>`;
    });
    html+=`</div></div>`;
  });
  document.getElementById('cardsView').innerHTML=html||`<div style="text-align:center;padding:60px;color:var(--text-dim);border:1px dashed var(--cream-dark);background:white">No deals match the current filters</div>`;
}

// ── TABLE ─────────────────────────────────────────────────────────────────────
function renderTable(data){
  const order=['Acquired','Exclusivity','Advanced Discussions','Early Discussions','Potential Opportunities','On Hold'];
  const sorted=[...data].sort((a,b)=>order.indexOf(a.status)-order.indexOf(b.status));
  let html='',lastS=null;
  sorted.forEach(d=>{
    const idx=liveDeals.indexOf(d);
    if(d.status!==lastS){html+=`<tr class="tbl-section"><td colspan="12">${d.status}</td></tr>`;lastS=d.status;}
    html+=`<tr onclick="openModal(${idx})">
      <td><span class="deal-status-pill ${pillCls(d.status)}" style="font-size:10px">${pillLbl(d.status)}</span></td>
      <td style="font-weight:500">${d.address||'—'}</td>
      <td class="muted">${d.neighbourhood?d.neighbourhood+', ':''} ${d.city}</td>
      <td style="font-weight:600">${d.beds||'—'}</td>
      <td class="right muted">${fmt(d.landPrice)}</td>
      <td class="right muted">${fmt(d.totalCost)}</td>
      <td class="right">${fmt(d.gdv)}</td>
      <td class="right" style="font-weight:500">${fmt(d.equity)}</td>
      <td class="right muted">${fmtYoc(d.yoc)}</td>
      <td class="muted">${d.developer||'—'}</td>
      <td class="muted">${d.intake||'—'}</td>
      <td class="muted" style="font-size:11px">${d.planning||'—'}</td>
    </tr>`;
  });
  document.getElementById('tableBody').innerHTML=html||'<tr><td colspan="12" style="text-align:center;padding:40px;color:var(--text-dim)">No results</td></tr>';
}

// ── DECLINED ──────────────────────────────────────────────────────────────────
function renderDeclined(data){
  let html='';
  data.forEach(d=>{
    const pc=d.status==='Lost'?'pill-lost':'pill-declined';
    html+=`<tr><td><span class="deal-status-pill ${pc}" style="font-size:10px">${d.status}</span></td>
      <td style="font-weight:500">${d.address||'—'}</td><td class="muted">${d.city}</td>
      <td class="muted">${d.area||'—'}</td><td>${d.beds||'—'}</td>
      <td class="muted" style="font-size:12px">${d.type||'—'}</td>
      <td class="muted" style="font-size:12px">${d.seller||'—'}</td>
      <td class="right muted">${fmt(d.landPrice)}</td></tr>`;
  });
  document.getElementById('declinedBody').innerHTML=html||'<tr><td colspan="8" style="text-align:center;padding:40px;color:var(--text-dim)">No results</td></tr>';
}

// ── NEXT ACTIONS ──────────────────────────────────────────────────────────────
function renderActions(filter){
  const data=filter==='all'?nextActions:nextActions.filter(a=>a.rag===filter);
  const lbl={red:'Urgent',amber:'Needs Attention',green:'In Hand'};
  let html='';
  data.forEach(a=>{
    const has=a.action&&a.action.trim();
    html+=`<div class="action-card"><div class="action-stripe stripe-${a.rag}"></div><div class="action-body">
      <div class="action-card-top">
        <div><div class="action-addr">${a.address}</div><div class="action-city-txt">${a.city}</div></div>
        <div class="action-rag-badge"><span class="rag-dot rag-${a.rag}"></span><span style="color:var(--text-dim)">${lbl[a.rag]}</span></div>
      </div>
      <div class="action-text-box ${has?'':'empty'}">${has?a.action:'Next action to be populated via shared tracker'}</div>
      <div class="action-footer">
        <span class="deal-status-pill ${pillCls(a.status)}" style="font-size:10px">${pillLbl(a.status)}</span>
        <span class="action-beds-txt">${a.beds} beds</span>
      </div>
    </div></div>`;
  });
  document.getElementById('actionsCards').innerHTML=html||`<div class="empty-state"><p>No actions in this category</p></div>`;
}

// ── MODAL ─────────────────────────────────────────────────────────────────────
function openModal(idx){
  const d=liveDeals[idx];
  document.getElementById('modalPill').innerHTML=`<span class="deal-status-pill ${pillCls(d.status)}">${pillLbl(d.status)}</span>`;
  document.getElementById('modalAddress').textContent=d.address||'—';
  document.getElementById('modalLocation').innerHTML=`${d.neighbourhood?d.neighbourhood+', ':''}${d.city}${d.ptal?' &nbsp;·&nbsp; '+d.ptal:''}`;

  const bedsTotal=d.beds||0;
  const studios=d.studios!=null?d.studios:'—';
  const ensuite=d.ensuite!=null?d.ensuite:'—';
  const other=(d.beds!=null&&d.studios!=null&&d.ensuite!=null)?(d.beds-d.studios-d.ensuite):'—';

  function row(label,value){
    const empty=value==null||value==='';
    return`<div class="modal-detail-item"><div class="modal-detail-label">${label}</div><div class="modal-detail-value${empty?' empty':''}">${empty?'Not available':value}</div></div>`;
  }

  document.getElementById('modalBody').innerHTML=`
    <!-- Financials -->
    <div class="modal-section-title">Financials</div>
    <div class="modal-fin-grid">
      <div class="modal-fin-box"><div class="modal-fin-label">Land Price</div><div class="modal-fin-value">${fmt(d.landPrice)}</div><div class="modal-fin-sub">${fmtFull(d.landPrice)}</div></div>
      <div class="modal-fin-box"><div class="modal-fin-label">Total Levered Cost</div><div class="modal-fin-value">${fmt(d.totalCost)}</div><div class="modal-fin-sub">${fmtFull(d.totalCost)}</div></div>
      <div class="modal-fin-box"><div class="modal-fin-label">GDV</div><div class="modal-fin-value">${fmt(d.gdv)}</div><div class="modal-fin-sub">${fmtFull(d.gdv)}</div></div>
      <div class="modal-fin-box"><div class="modal-fin-label">Equity Required</div><div class="modal-fin-value">${fmt(d.equity)}</div><div class="modal-fin-sub">YoC: ${fmtYoc(d.yoc)}</div></div>
    </div>

    <!-- Bed Split -->
    <div class="modal-section-title">Bed Split</div>
    <div class="modal-bed-split">
      <div class="modal-bed-box"><div class="modal-bed-num">${bedsTotal||'—'}</div><div class="modal-bed-lbl">Total Beds</div></div>
      <div class="modal-bed-box"><div class="modal-bed-num">${studios}</div><div class="modal-bed-lbl">Studios</div></div>
      <div class="modal-bed-box"><div class="modal-bed-num">${ensuite}</div><div class="modal-bed-lbl">Ensuite</div></div>
    </div>

    <!-- Deal Details -->
    <div class="modal-section-title">Deal Details</div>
    <div class="modal-details-grid">
      ${row('Full Address', d.address)}
      ${row('Developer', d.developer)}
      ${row('Seller / Vendor', d.seller)}
      ${row('Marketing', d.marketing)}
      ${row('Deal Type', d.type)}
      ${row('Planning Status', d.planning)}
      ${row('Intake Date (AY)', d.intake)}
      ${row('Gateway 2', d.gateway)}
      ${row('PTAL Rating', d.ptal)}
      ${row('GIA (Sq. ft.)', d.gia ? d.gia.toLocaleString() : null)}
    </div>

    ${d.notes?`<div class="modal-section-title">Notes</div><div class="modal-notes">${d.notes}</div>`:''}
  `;
  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow='hidden';
}

function closeModal(e){if(e.target===document.getElementById('modalOverlay'))closeModalDirect();}
function closeModalDirect(){
  document.getElementById('modalOverlay').classList.remove('open');
  document.body.style.overflow='';
}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModalDirect();});

// ── FILTERS ───────────────────────────────────────────────────────────────────
function getFiltered(){
  const s=(document.getElementById('searchInput')?.value||'').toLowerCase();
  return liveDeals.filter(d=>{
    const statusOk=activeStatus==='All'||d.status===activeStatus;
    const cityOk=activeCity==='All'||cityMatch(d,activeCity);
    const searchOk=!s||[d.address,d.city,d.seller,d.neighbourhood,d.developer].join(' ').toLowerCase().includes(s);
    return statusOk&&cityOk&&searchOk;
  });
}
function applyFilters(){const d=getFiltered();renderCards(d);renderTable(d);}
function setStatus(s,btn){activeStatus=s;document.querySelectorAll('#statusPills .pill-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');applyFilters();}
function setCity(c,btn){
  activeCity=activeCity===c?'All':c;
  document.querySelectorAll('#cityPills .pill-btn').forEach(b=>b.classList.remove('city-active'));
  if(activeCity!=='All')btn.classList.add('city-active');
  applyFilters();
}
function applyDeclinedFilters(){
  const s=(document.getElementById('decSearch')?.value||'').toLowerCase();
  renderDeclined(declinedDeals.filter(d=>(decActiveCity==='All'||d.city===decActiveCity)&&(!s||[d.address,d.city,d.area,d.seller].join(' ').toLowerCase().includes(s))));
}
function setDecCity(c,btn){decActiveCity=c;document.querySelectorAll('#decCityPills .pill-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');applyDeclinedFilters();}
function filterActions(f,btn){document.querySelectorAll('.rag-pill-btn').forEach(b=>b.className='rag-pill-btn');btn.classList.add('rag-active-'+f);renderActions(f);}
function setView(v){
  currentView=v;
  document.getElementById('cardsView').style.display=v==='cards'?'block':'none';
  document.getElementById('tableView').style.display=v==='table'?'block':'none';
  document.getElementById('cardsBtn').classList.toggle('active',v==='cards');
  document.getElementById('tableBtn').classList.toggle('active',v==='table');
}

// ── TABS ──────────────────────────────────────────────────────────────────────
function switchTab(name,btn){
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  if(btn)btn.classList.add('active');
  document.getElementById('mainFilters').style.display=name==='pipeline'?'flex':'none';
  document.getElementById('decFilters').style.display=name==='declined'?'flex':'none';
}
function switchTabByName(name){const btns=document.querySelectorAll('.tab-btn');['pipeline','declined','actions'].forEach((n,i)=>{if(n===name)switchTab(n,btns[i]);});}
function checkPw(){
  if(document.getElementById('pwInput').value==='PBSA2026'){
    document.getElementById('gate').style.display='none';
  }else{
    document.getElementById('pwError').style.display='block';
    document.getElementById('pwInput').value='';
    document.getElementById('pwInput').focus();
  }
}
renderKPIs();applyFilters();renderDeclined(declinedDeals);renderActions('all');
</script>
</body>
</html>
