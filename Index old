<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PBSA Platform · Pipeline Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
:root{
  --olive:#2c2b1e;--cream:#f0ece0;--cream-mid:#e8e3d4;--cream-dark:#d8d2c0;--parchment:#f5f2ea;
  --gold:#c8a96e;--gold-light:#dfc08a;
  --text-dark:#1e1d14;--text-mid:#4a4637;--text-muted:#7a7460;--text-dim:#a09880;
  --red:#c0392b;--red-bg:rgba(192,57,43,0.1);
  --green:#2d5a3d;--green-bg:rgba(45,90,61,0.12);
  --amber:#b8830a;--amber-bg:rgba(184,131,10,0.1);
  --blue:#2a4a6b;--blue-bg:rgba(42,74,107,0.1);
  --grey:#5a5650;--grey-bg:rgba(90,86,80,0.1);
  --purple:#5a3d6b;--purple-bg:rgba(90,61,107,0.1);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:var(--parchment);color:var(--text-dark);min-height:100vh;}

/* ── GATE ── */
#gate{position:fixed;inset:0;background:var(--olive);display:flex;align-items:center;justify-content:center;z-index:9999;flex-direction:column;gap:32px;}
.gate-logo{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;color:var(--cream);letter-spacing:0.05em;}
.gate-logo em{color:var(--gold);font-style:italic;}
.gate-box{display:flex;flex-direction:column;align-items:center;gap:12px;width:300px;}
.gate-label{font-size:11px;letter-spacing:0.15em;text-transform:uppercase;color:var(--text-dim);}
.gate-input{width:100%;background:rgba(255,255,255,0.06);border:1px solid rgba(200,169,110,0.3);color:var(--cream);padding:12px 16px;font-family:'DM Mono',monospace;font-size:14px;letter-spacing:0.1em;outline:none;text-align:center;transition:border-color 0.2s;}
.gate-input:focus{border-color:var(--gold);}
.gate-input::placeholder{color:rgba(200,169,110,0.3);}
.gate-btn{width:100%;background:var(--gold);border:none;color:var(--olive);padding:12px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;transition:background 0.2s;}
.gate-btn:hover{background:var(--gold-light);}
.gate-error{font-size:11px;color:#e07070;letter-spacing:0.05em;display:none;}

/* ── HEADER ── */
.header{background:var(--olive);padding:0 40px;display:flex;align-items:center;justify-content:space-between;height:56px;position:sticky;top:0;z-index:200;}
.header-logo{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:400;color:var(--cream);}
.header-logo em{color:var(--gold);font-style:italic;}
.header-right{display:flex;align-items:center;gap:28px;}
.header-meta{font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:rgba(200,185,155,0.5);}
.header-date{font-size:11px;color:rgba(200,185,155,0.7);}
.add-btn{background:var(--gold);border:none;color:var(--olive);padding:8px 18px;font-family:'DM Sans',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;transition:background 0.2s;}
.add-btn:hover{background:var(--gold-light);}

/* ── HERO ── */
.hero{background:var(--olive);padding:40px 40px 48px;display:flex;align-items:flex-end;justify-content:space-between;gap:40px;}
.hero-left h1{font-family:'Cormorant Garamond',serif;font-size:56px;font-weight:300;color:var(--cream);line-height:1;}
.hero-left h1 em{color:var(--gold);font-style:italic;}
.hero-left .sub{font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(200,185,155,0.5);margin-top:14px;}
.kpi-grid{display:flex;border:1px solid rgba(200,169,110,0.2);}
.kpi{padding:18px 28px;border-right:1px solid rgba(200,169,110,0.15);min-width:130px;text-align:center;}
.kpi:last-child{border-right:none;}
.kpi-label{font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(200,185,155,0.45);margin-bottom:10px;}
.kpi-value{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:400;color:var(--cream);line-height:1;}
.kpi-value.gold{color:var(--gold);}
.kpi-value.red-val{color:#e08070;}
.kpi-sub{font-size:10px;color:rgba(200,185,155,0.35);margin-top:5px;}
.kpi-link{font-size:10px;color:var(--gold);text-decoration:underline;cursor:pointer;margin-top:4px;display:block;}

/* ── LEGEND STRIP ── */
.kpi-legend{background:rgba(20,19,12,0.95);padding:9px 40px;display:flex;align-items:center;flex-wrap:wrap;gap:0;}
.kpi-legend-item{font-size:10px;color:rgba(200,185,155,0.5);}
.kpi-legend-item strong{color:rgba(200,185,155,0.78);font-weight:500;}
.kpi-legend-sep{color:rgba(200,169,110,0.3);margin:0 14px;}

/* ── TABS ── */
.tabs-bar{background:var(--olive);border-top:1px solid rgba(200,169,110,0.15);padding:0 40px;display:flex;}
.tab-btn{padding:16px 4px;margin-right:32px;font-family:'DM Sans',sans-serif;font-size:13px;color:rgba(200,185,155,0.45);background:none;border:none;border-bottom:2px solid transparent;cursor:pointer;transition:all 0.2s;}
.tab-btn:hover{color:var(--cream);}
.tab-btn.active{color:var(--cream);border-bottom-color:var(--gold);font-weight:500;}

/* ── FILTERS ── */
.filters-bar{background:var(--cream-mid);border-bottom:1px solid var(--cream-dark);padding:14px 40px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.filter-sep{width:1px;height:20px;background:var(--cream-dark);margin:0 6px;}
.filter-label-sm{font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-dim);margin-right:2px;}
.filter-group{display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
.pill-btn{padding:5px 14px;border-radius:999px;border:1px solid var(--cream-dark);background:transparent;font-family:'DM Sans',sans-serif;font-size:12px;color:var(--text-muted);cursor:pointer;transition:all 0.15s;white-space:nowrap;}
.pill-btn:hover{border-color:var(--text-mid);color:var(--text-dark);}
.pill-btn.active{background:var(--olive);border-color:var(--olive);color:var(--cream);}
.pill-btn.city-active{background:var(--text-dark);border-color:var(--text-dark);color:var(--cream);}
.search-input{padding:5px 14px;border:1px solid var(--cream-dark);background:var(--parchment);font-family:'DM Sans',sans-serif;font-size:12px;color:var(--text-dark);outline:none;width:220px;transition:border-color 0.2s;}
.search-input:focus{border-color:var(--gold);}
.search-input::placeholder{color:var(--text-dim);}
.view-toggle{margin-left:auto;display:flex;border:1px solid var(--cream-dark);overflow:hidden;}
.view-btn{padding:5px 16px;background:none;border:none;font-family:'DM Sans',sans-serif;font-size:12px;color:var(--text-muted);cursor:pointer;transition:all 0.15s;}
.view-btn.active{background:var(--olive);color:var(--cream);}
.view-btn:first-child{border-right:1px solid var(--cream-dark);}

/* ── MAIN ── */
.main{padding:32px 40px 60px;}
.tab-panel{display:none;}
.tab-panel.active{display:block;}

/* ── STATUS SECTIONS ── */
.status-section{margin-bottom:36px;}
.status-heading{display:flex;align-items:center;gap:12px;margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--cream-dark);}
.status-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
.status-heading-text{font-size:11px;letter-spacing:0.14em;text-transform:uppercase;font-weight:500;color:var(--text-mid);}
.status-count{font-family:'DM Mono',monospace;font-size:11px;color:var(--text-dim);background:var(--cream-mid);border:1px solid var(--cream-dark);padding:1px 8px;border-radius:999px;}

/* ── CARDS ── */
.cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px;}
.deal-card{background:white;border:1px solid var(--cream-dark);padding:22px 22px 18px;transition:box-shadow 0.2s,transform 0.15s;cursor:pointer;}
.deal-card:hover{box-shadow:0 4px 24px rgba(44,43,30,0.12);transform:translateY(-1px);}
.deal-card-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:6px;}
.deal-address{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:400;color:var(--text-dark);line-height:1.2;padding-right:8px;}
.deal-status-pill{font-size:10px;letter-spacing:0.08em;text-transform:uppercase;padding:3px 10px;border-radius:999px;font-weight:500;white-space:nowrap;flex-shrink:0;}
.pill-acquired{background:var(--green-bg);color:var(--green);border:1px solid rgba(45,90,61,0.2);}
.pill-exclusivity{background:var(--amber-bg);color:var(--amber);border:1px solid rgba(184,131,10,0.2);}
.pill-advanced{background:var(--blue-bg);color:var(--blue);border:1px solid rgba(42,74,107,0.2);}
.pill-early{background:rgba(160,152,128,0.12);color:var(--text-mid);border:1px solid rgba(160,152,128,0.25);}
.pill-hold{background:var(--grey-bg);color:var(--grey);border:1px solid rgba(90,86,80,0.2);}
.pill-lost{background:var(--red-bg);color:var(--red);border:1px solid rgba(192,57,43,0.2);}
.pill-potential{background:var(--purple-bg);color:var(--purple);border:1px solid rgba(90,61,107,0.2);}
.pill-declined{background:var(--grey-bg);color:var(--grey);border:1px solid rgba(90,86,80,0.2);}
.deal-location{font-size:12px;color:var(--text-muted);margin-bottom:16px;display:flex;align-items:center;gap:5px;}
.deal-location::before{content:'◆';font-size:7px;color:var(--gold);}
.deal-location strong{color:var(--text-mid);font-weight:500;}
.deal-metrics{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:16px;}
.metric-box{background:var(--parchment);border:1px solid var(--cream-dark);padding:10px 10px 8px;}
.metric-label{font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-dim);margin-bottom:5px;}
.metric-value{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:400;color:var(--text-dark);line-height:1;}
.metric-sub{font-size:10px;color:var(--text-dim);margin-top:3px;}
.deal-tags{display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
.tag{font-size:10px;padding:2px 9px;border-radius:999px;border:1px solid var(--cream-dark);color:var(--text-muted);background:var(--parchment);}
.tag.gold-tag{border-color:rgba(200,169,110,0.35);color:var(--gold);background:rgba(200,169,110,0.07);}
.deal-intake{margin-left:auto;font-size:11px;color:var(--text-dim);}
.deal-notes{margin-top:12px;padding:8px 10px;background:rgba(200,169,110,0.06);border-left:2px solid var(--gold);font-size:11px;color:var(--text-muted);line-height:1.5;font-style:italic;}
.card-hint{margin-top:12px;font-size:10px;color:var(--text-dim);letter-spacing:0.05em;text-align:right;opacity:0;transition:opacity 0.2s;}
.deal-card:hover .card-hint{opacity:1;}

/* ── TABLE ── */
.table-wrap{overflow-x:auto;border:1px solid var(--cream-dark);background:white;}
table{width:100%;border-collapse:collapse;min-width:900px;}
thead tr{background:var(--cream-mid);border-bottom:1px solid var(--cream-dark);}
th{padding:10px 14px;text-align:left;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-dim);font-weight:500;white-space:nowrap;}
tbody tr{border-bottom:1px solid var(--cream-mid);transition:background 0.12s;cursor:pointer;}
tbody tr:hover{background:var(--parchment);}
tbody tr:last-child{border-bottom:none;}
td{padding:11px 14px;font-size:13px;color:var(--text-dark);vertical-align:middle;}
td.muted{color:var(--text-muted);font-size:12px;}
td.right{text-align:right;font-variant-numeric:tabular-nums;}
.tbl-section td{background:var(--cream-mid);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-dim);padding:6px 14px;border-top:1px solid var(--cream-dark);cursor:default;}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(20,19,12,0.65);z-index:1000;display:none;align-items:center;justify-content:center;padding:24px;}
.modal-overlay.open{display:flex;}
.modal{background:var(--parchment);width:100%;max-width:680px;max-height:90vh;overflow-y:auto;position:relative;animation:modalIn 0.22s ease;}
@keyframes modalIn{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
.modal-header{background:var(--olive);padding:28px 32px 24px;position:relative;}
.modal-close{position:absolute;top:20px;right:24px;background:none;border:none;color:rgba(200,185,155,0.5);font-size:20px;cursor:pointer;line-height:1;padding:4px 8px;transition:color 0.2s;}
.modal-close:hover{color:var(--cream);}
.modal-status-pill{display:inline-block;margin-bottom:10px;}
.modal-address{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;color:var(--cream);line-height:1.15;}
.modal-location{font-size:12px;color:rgba(200,185,155,0.55);margin-top:6px;display:flex;align-items:center;gap:6px;}
.modal-location::before{content:'◆';font-size:7px;color:var(--gold);}
.modal-body{padding:28px 32px;}

/* Financials highlight row */
.modal-fin-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:24px;}
.modal-fin-box{background:white;border:1px solid var(--cream-dark);padding:14px 14px 12px;}
.modal-fin-label{font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-dim);margin-bottom:6px;}
.modal-fin-value{font-family:'Cormorant Garamond',serif;font-size:22px;color:var(--text-dark);line-height:1;}
.modal-fin-sub{font-size:10px;color:var(--text-dim);margin-top:3px;}

/* Details grid */
.modal-section-title{font-size:10px;letter-spacing:0.14em;text-transform:uppercase;color:var(--text-dim);margin-bottom:12px;padding-bottom:6px;border-bottom:1px solid var(--cream-dark);}
.modal-details-grid{display:grid;grid-template-columns:1fr 1fr;gap:0;margin-bottom:24px;border:1px solid var(--cream-dark);background:white;}
.modal-detail-row{display:contents;}
.modal-detail-item{padding:10px 16px;border-bottom:1px solid var(--cream-mid);border-right:1px solid var(--cream-mid);}
.modal-detail-item:nth-child(even){border-right:none;}
.modal-detail-label{font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-dim);margin-bottom:3px;}
.modal-detail-value{font-size:13px;color:var(--text-dark);font-weight:400;}
.modal-detail-value.empty{color:var(--text-dim);font-style:italic;font-size:12px;}

/* Bed split */
.modal-bed-split{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:24px;}
.modal-bed-box{background:white;border:1px solid var(--cream-dark);padding:12px 14px;text-align:center;}
.modal-bed-num{font-family:'Cormorant Garamond',serif;font-size:26px;color:var(--text-dark);line-height:1;}
.modal-bed-lbl{font-size:9px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-dim);margin-top:4px;}

/* Notes */
.modal-notes{background:rgba(200,169,110,0.07);border-left:3px solid var(--gold);padding:12px 16px;font-size:12px;color:var(--text-mid);line-height:1.6;font-style:italic;}

/* ── NEXT ACTIONS ── */
.actions-intro{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:24px;gap:20px;}
.actions-intro-text h2{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;color:var(--text-dark);}
.actions-intro-text p{font-size:12px;color:var(--text-muted);margin-top:4px;line-height:1.6;}
.rag-legend-row{display:flex;gap:16px;flex-shrink:0;align-items:center;}
.rag-leg-item{display:flex;align-items:center;gap:7px;font-size:11px;color:var(--text-muted);}
.rag-filter-strip{display:flex;gap:8px;margin-bottom:20px;}
.rag-pill-btn{display:flex;align-items:center;gap:7px;padding:6px 16px;border:1px solid var(--cream-dark);background:white;font-family:'DM Sans',sans-serif;font-size:12px;color:var(--text-muted);cursor:pointer;transition:all 0.15s;border-radius:999px;}
.rag-pill-btn:hover{border-color:var(--text-mid);color:var(--text-dark);}
.rag-pill-btn.rag-active-all{background:var(--olive);border-color:var(--olive);color:var(--cream);}
.rag-pill-btn.rag-active-red{background:var(--red-bg);border-color:var(--red);color:var(--red);}
.rag-pill-btn.rag-active-amber{background:var(--amber-bg);border-color:var(--amber);color:var(--amber);}
.rag-pill-btn.rag-active-green{background:var(--green-bg);border-color:#4a9e6b;color:#2d5a3d;}
.rag-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.rag-green{background:#4a9e6b;box-shadow:0 0 4px rgba(74,158,107,0.5);}
.rag-amber{background:var(--amber);box-shadow:0 0 4px rgba(184,131,10,0.5);}
.rag-red{background:var(--red);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{box-shadow:0 0 4px rgba(192,57,43,0.4);}50%{box-shadow:0 0 10px rgba(192,57,43,0.7);}}
.actions-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:14px;}
.action-card{background:white;border:1px solid var(--cream-dark);padding:20px;position:relative;transition:box-shadow 0.2s;}
.action-card:hover{box-shadow:0 2px 16px rgba(44,43,30,0.08);}
.action-stripe{position:absolute;left:0;top:0;bottom:0;width:4px;}
.stripe-red{background:var(--red);}
.stripe-amber{background:var(--amber);}
.stripe-green{background:#4a9e6b;}
.action-body{padding-left:12px;}
.action-card-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:4px;}
.action-addr{font-family:'Cormorant Garamond',serif;font-size:17px;color:var(--text-dark);line-height:1.2;}
.action-city-txt{font-size:11px;color:var(--text-muted);margin-bottom:12px;}
.action-rag-badge{display:flex;align-items:center;gap:5px;font-size:10px;letter-spacing:0.08em;text-transform:uppercase;flex-shrink:0;}
.action-text-box{background:var(--parchment);border:1px solid var(--cream-dark);padding:10px 12px;font-size:12px;color:var(--text-mid);line-height:1.6;margin-bottom:12px;min-height:50px;font-style:italic;}
.action-text-box.empty{color:var(--text-dim);font-style:normal;font-size:11px;}
.action-footer{display:flex;align-items:center;gap:8px;}
.action-beds-txt{font-size:11px;color:var(--text-dim);}
.empty-state{text-align:center;padding:60px 20px;border:1px dashed var(--cream-dark);background:white;grid-column:1/-1;}
.empty-state p{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--text-muted);margin-bottom:6px;}

::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:var(--cream-mid);}
::-webkit-scrollbar-thumb{background:var(--cream-dark);}
</style>
</head>
<body>

<!-- GATE -->
<div id="gate">
  <div class="gate-logo">PBSA <em>Platform</em></div>
  <div class="gate-box">
    <div class="gate-label">Enter Access Password</div>
    <input class="gate-input" id="pwInput" type="password" placeholder="••••••••" onkeydown="if(event.key==='Enter')checkPw()">
    <button class="gate-btn" onclick="checkPw()">Access Tracker</button>
    <div class="gate-error" id="pwError">Incorrect password. Please try again.</div>
  </div>
</div>

<!-- HEADER -->
<div class="header">
  <div class="header-logo">PBSA <em>Platform</em></div>
  <div class="header-right">
    <span class="header-meta">Pipeline Tracker</span>
    <span class="header-date" id="headerDate"></span>
    <button class="add-btn">+ Add Deal</button>
  </div>
</div>

<!-- HERO -->
<div class="hero">
  <div class="hero-left">
    <h1>PBSA <em>Pipeline</em></h1>
    <div class="sub">KATCH · VALPRE CAPITAL · CKC PROPERTIES</div>
  </div>
  <div class="kpi-grid" id="kpiGrid"></div>
</div>

<!-- LEGEND -->
<div class="kpi-legend">
  <span class="kpi-legend-item">⬡ <strong>Total Beds</strong> — all live pipeline deals, excl. lost &amp; declined</span>
  <span class="kpi-legend-sep">·</span>
  <span class="kpi-legend-item">⬡ <strong>Equity Required</strong> — active deals only (Acquired, Exclusivity, Advanced, Early Stage); On Hold excluded</span>
  <span class="kpi-legend-sep">·</span>
  <span class="kpi-legend-item">⬡ <strong>Declined</strong> — Declined Opportunities only; Lost shown separately in Declined &amp; Lost tab</span>
</div>

<!-- TABS -->
<div class="tabs-bar">
  <button class="tab-btn active" onclick="switchTab('pipeline',this)">Pipeline</button>
  <button class="tab-btn" onclick="switchTab('declined',this)">Declined &amp; Lost</button>
  <button class="tab-btn" onclick="switchTab('actions',this)">Next Actions</button>
</div>

<!-- PIPELINE FILTERS -->
<div class="filters-bar" id="mainFilters">
